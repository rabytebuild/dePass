APP_NAME="dePass Version 2026.07.22"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database – SQLite (default, no configuration needed)
# ---------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite (optional override)

# ---------------------------------------------------------------------------
# Database – MySQL (uncomment and fill in to switch from SQLite)
# ---------------------------------------------------------------------------
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=depass
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# Audit logging
# ---------------------------------------------------------------------------
AUDIT_LOG_REQUESTS=false

# ---------------------------------------------------------------------------
# Scanner defaults
# ---------------------------------------------------------------------------
SCANNER_DEFAULT_THEME=dark
SCANNER_TORCH_ENABLED=false
SCANNER_VIBRATION_ENABLED=true
SCANNER_SOUND_ENABLED=true
SCANNER_AUTO_CLOSE_DELAY=3

# ---------------------------------------------------------------------------
# Offline sync
# ---------------------------------------------------------------------------
SYNC_BATCH_SIZE=100
SYNC_MAX_AGE_DAYS=90

# ---------------------------------------------------------------------------
# App version
# ---------------------------------------------------------------------------
APP_VERSION=2026.07.22

VITE_APP_NAME="${APP_NAME}"
