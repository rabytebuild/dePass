{
  "$schema": "https://opencode.ai/config.json",

  // ── Project identity ──────────────────────────────────────────
  "username": "dePass",
  "instructions": ["track.md", "QUICK_COMMANDS.md"],

  // ── Custom agents ─────────────────────────────────────────────
  "agent": {
    "laravel": {
      "description": "Expert Laravel/PHP developer for backend work",
      "mode": "subagent",
      "prompt": "You are a senior Laravel developer. Focus on PHP 8.4, Eloquent, Sanctum auth, REST API design, SQLite/MySQL, testing with PHPUnit, and artisan commands. Follow existing patterns in backend/app/."
    },
    "flutter": {
      "description": "Expert Flutter/Dart developer for mobile app work",
      "mode": "subagent",
      "prompt": "You are a senior Flutter developer. Focus on Material Design 3, Provider state management, mobile_scanner, flutter_secure_storage, and Android release builds. Follow existing patterns in mobile/lib/."
    },
    "fullstack": {
      "description": "Cross-stack agent for Laravel + Flutter changes",
      "mode": "subagent",
      "prompt": "You are a full-stack developer for dePass. When adding a feature, work systematically: (1) backend migration + model + controller + route, (2) run php artisan test, (3) Flutter screen + provider + service, (4) run flutter analyze + flutter test. Follow existing patterns in both stacks."
    }
  },

  // ── Custom commands ───────────────────────────────────────────
  "command": {
    "backend:setup": {
      "description": "Set up Laravel backend from scratch",
      "template": "Run: cd backend && composer install && cp .env.example .env && php artisan key:generate && touch database/database.sqlite && php artisan migrate:fresh --seed && php artisan serve --host=0.0.0.0 --port=8000"
    },
    "backend:test": {
      "description": "Run Laravel tests",
      "template": "Run: cd backend && php artisan test"
    },
    "backend:reset": {
      "description": "Reset database with fresh seed",
      "template": "Run: cd backend && php artisan migrate:fresh --seed"
    },
    "mobile:build": {
      "description": "Build Flutter release APK",
      "template": "Run: cd mobile && flutter clean && flutter pub get && flutter build apk --release"
    },
    "mobile:analyze": {
      "description": "Run Flutter static analysis",
      "template": "Run: cd mobile && flutter analyze"
    },
    "mobile:test": {
      "description": "Run Flutter tests",
      "template": "Run: cd mobile && flutter test"
    },
    "preflight": {
      "description": "Run full preflight checks (backend + mobile)",
      "template": "Run: bash scripts/local-preflight.sh"
    },
    "release:build": {
      "description": "Run full release build script",
      "template": "Run: bash build-release.sh"
    },
    "admin:dev": {
      "description": "Start shadcn/ui admin panel dev server",
      "template": "Run: cd admin && npm run dev"
    },
    "admin:build": {
      "description": "Build shadcn/ui admin panel for production",
      "template": "Run: cd admin && npm run build"
    },
    "tui:start": {
      "description": "Start the terminal TUI app",
      "template": "Run: cd tui && npm start"
    },
    "tui:dev": {
      "description": "Start the terminal TUI in watch mode",
      "template": "Run: cd tui && npm run dev"
    }
  },

  // ── Reference docs ────────────────────────────────────────────
  "references": {
    "track": {
      "path": "track.md",
      "description": "Use for implementation status and checklist tracking"
    },
    "commands": {
      "path": "QUICK_COMMANDS.md",
      "description": "Use for copy-paste ready dev commands"
    },
    "backend": {
      "path": "backend",
      "description": "Use for Laravel backend API, models, controllers, routes"
    },
    "mobile": {
      "path": "mobile",
      "description": "Use for Flutter mobile app screens, providers, widgets"
    },
    "admin": {
      "path": "admin",
      "description": "Use for the shadcn/ui web admin panel (React + Tailwind)"
    },
    "tui": {
      "path": "tui",
      "description": "Use for the terminal TUI app (Node.js + Ink)"
    }
  },

  // ── Permissions ───────────────────────────────────────────────
  "permission": {
    "bash": {
      "git *": "allow",
      "*": "ask"
    }
  }
}
